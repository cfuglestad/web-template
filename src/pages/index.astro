---
const title = "Astro Portfolio Project";
const description = "A production-ready Astro starter with shared CI and GitHub Pages deployment.";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <main>
      <p class="eyebrow">Astro project template</p>
      <h1>{title}</h1>
      <p>{description}</p>
    </main>
  </body>
</html>

<style>
  :global(*) { box-sizing: border-box; }
  :global(body) {
    margin: 0;
    min-height: 100vh;
    display: grid;
    place-items: center;
    font-family: system-ui, sans-serif;
    background: #f7f7f5;
    color: #171717;
  }
  main { width: min(680px, 90vw); }
  .eyebrow { text-transform: uppercase; letter-spacing: 0.12em; font-size: 0.8rem; }
  h1 { font-size: clamp(2.5rem, 8vw, 5rem); line-height: 0.95; margin: 1rem 0; }
  p { font-size: 1.1rem; line-height: 1.6; }
</style>
